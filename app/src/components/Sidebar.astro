---
import Nav from './Nav.astro';
import SocialLinks from './SocialLinks.astro';
import LanguagePicker from './LanguagePicker.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<aside class="sidebar">
  <!-- Header: name + title + subtitle -->
  <div class="sidebar-identity">
    <h1 class="sidebar-name">
      <a href="/">Rodrigo Torrico</a>
    </h1>
    <p class="sidebar-title">Senior Fullstack Engineer</p>
    <p class="sidebar-subtitle">AI-Augmented Development</p>
  </div>

  <!-- Nav: centered between header and footer -->
  <div class="sidebar-nav">
    <Nav />
  </div>

  <!-- Footer: social links + lang/CV row -->
  <div class="sidebar-bottom">
    <SocialLinks />
    <div class="sidebar-footer-row">
      <div class="sidebar-lang-area">
        <ThemeToggle />
        <div class="sidebar-divider-v"></div>
        <LanguagePicker />
      </div>
      <a href="/Rodrigo-Torrico-Resume.pdf" download class="cv-button">Download CV</a>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .sidebar {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: fixed;
      top: 0;
      left: 0;
      width: 420px;
      height: 100vh;
      padding: 48px;
      z-index: 10;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--sidebar-border);
      transition: background 0.3s ease, border-color 0.3s ease;
    }
  }

  .sidebar-identity {
    display: flex;
    flex-direction: column;
  }

  .sidebar-name {
    font-size: 36px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.05em;
    color: var(--color-text);
    margin: 0;
  }

  .sidebar-name a {
    text-decoration: none;
    color: inherit;
  }

  .sidebar-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-accent);
    margin: 8px 0 0;
    line-height: 1.55;
  }

  .sidebar-subtitle {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-text-faint);
    margin: 8px 0 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .sidebar-nav {
    /* Nav sits naturally in the middle via justify-between on parent */
  }

  .sidebar-bottom {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .sidebar-footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 25px;
    border-top: 1px solid var(--color-border);
  }

  .sidebar-lang-area {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .sidebar-divider-v {
    width: 1px;
    height: 16px;
    background-color: var(--color-border);
  }

  .cv-button {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none;
    background-color: var(--color-accent-teal-bg);
    padding: 8px 16px;
    border-radius: 6px;
    transition: background-color 0.2s ease-in-out;
  }

  .cv-button:hover {
    background-color: var(--color-border);
  }
</style>
