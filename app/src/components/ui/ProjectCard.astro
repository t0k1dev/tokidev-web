---
import TechPill from './TechPill.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
  title: string;
  description: string;
  url: string | null;
  github: string | null;
  tech: string[];
  image: string | null;
}

const { title, description, url, github, tech, image } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const externalLink = url ?? github;
---

<article class="project-card" data-reveal>
  {image && (
    <div class="project-image-wrap">
      <img src={image} alt={`${title} screenshot`} loading="lazy" width="672" height="378" class="project-image" />
      <div class="project-image-gradient"></div>
    </div>
  )}

  <div class="project-body">
    <div class="project-header">
      <h3 class="project-title">{title}</h3>
      {externalLink && (
        <a href={externalLink} target="_blank" rel="noopener noreferrer" aria-label={`Open ${title}`} class="project-external">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      )}
    </div>

    <p class="project-description">{description}</p>

    <div class="project-tech">
      {tech.map((name) => (
        <TechPill name={name} variant="project" />
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    background-color: var(--color-surface);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .project-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .project-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    opacity: 0.6;
    filter: saturate(0);
    display: block;
  }

  .project-image-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-surface), transparent);
  }

  .project-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 32px;
  }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .project-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0;
    line-height: 1.33;
  }

  .project-external {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color 0.2s ease-in-out;
    margin-top: 4px;
  }

  .project-external:hover {
    color: var(--color-accent);
  }

  .project-description {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.625;
    margin: 0;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 3px;
  }
</style>
