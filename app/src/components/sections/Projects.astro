---
import ProjectCard from '../ui/ProjectCard.astro';
import SectionLabel from '../ui/SectionLabel.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const data = await import(`../../data/${lang}/projects.json`);

interface Project {
  title: string;
  description: string;
  url: string | null;
  github: string | null;
  tech: string[];
  image: string | null;
}
---

<section id="projects" aria-label="Projects" class="section" data-reveal>
  <SectionLabel>{t('nav.projects')}</SectionLabel>

  <div class="project-grid">
    {data.projects.map((project: Project) => (
      <ProjectCard
        title={project.title}
        description={project.description}
        url={project.url}
        github={project.github}
        tech={project.tech}
        image={project.image}
      />
    ))}
  </div>
</section>

<style>
  .project-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
</style>
