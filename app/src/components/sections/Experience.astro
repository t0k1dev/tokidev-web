---
import ExperienceCard from '../ui/ExperienceCard.astro';
import SectionLabel from '../ui/SectionLabel.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const data = await import(`../../data/${lang}/experience.json`);

interface Role {
  title: string;
  company: string;
  companyUrl: string | null;
  period: string;
  endDate: string | null;
  story: string;
  bullets: string[];
  tech: string[];
}
---

<section id="experience" aria-label="Work experience" class="section" data-reveal>
  <SectionLabel>{t('nav.experience')}</SectionLabel>

  <div class="experience-list">
    {data.roles.map((role: Role) => (
      <ExperienceCard
        title={role.title}
        company={role.company}
        companyUrl={role.companyUrl}
        period={role.period}
        endDate={role.endDate}
        story={role.story}
        bullets={role.bullets}
        tech={role.tech}
      />
    ))}
  </div>
</section>

<style>
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }
</style>
