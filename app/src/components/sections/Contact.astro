---
import CopyEmail from '../CopyEmail.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const data = await import(`../../data/${lang}/contact.json`);
---

<footer id="contact" aria-label="Contact" class="section">
  <h2 class="section-label">{t('nav.contact')}</h2>

  <div class="contact-content">
    <h3 class="contact-headline">{t('contact.headline')}</h3>

    <div class="contact-body">
      <div class="contact-email-row">
        <a href={`mailto:${data.email}`} class="email-link">{data.email}</a>
        <CopyEmail />
      </div>

      <div class="contact-details-grid">
        <div class="contact-detail-group">
          <span class="detail-label">Location</span>
          <p class="detail-value">📍 {data.location}</p>
        </div>
        <div class="contact-detail-group">
          <span class="detail-label">Languages</span>
          <p class="detail-value">{data.languages.join(' / ')}</p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin: 0 0 48px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-accent), transparent);
    opacity: 0.35;
  }

  @media (max-width: 1023px) {
    .section-label {
      position: sticky;
      top: 0;
      z-index: 5;
      padding: 16px 0;
      background-color: color-mix(in srgb, var(--color-bg) 80%, transparent);
      backdrop-filter: blur(8px);
      margin: 0 0 24px;
    }
  }

  .contact-content {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .contact-headline {
    font-size: 48px;
    font-weight: 900;
    color: var(--color-text-heading);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  @media (min-width: 1024px) {
    .contact-headline {
      font-size: 72px;
    }
  }

  .contact-body {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .contact-email-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
  }

  .email-link {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: rgba(142, 213, 255, 0.3);
    text-underline-offset: 4px;
    transition: text-decoration-color 0.2s ease-in-out;
  }

  @media (min-width: 1024px) {
    .email-link {
      font-size: 36px;
    }
  }

  .email-link:hover {
    text-decoration-color: var(--color-accent);
  }

  .contact-details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    padding-top: 49px;
    border-top: 1px solid rgba(62, 72, 79, 0.2);
  }

  .contact-detail-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .detail-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .detail-value {
    font-size: 16px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
