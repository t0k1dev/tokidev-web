---
import RecommendationCard from '../ui/RecommendationCard.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const data = await import(`../../data/${lang}/recommendations.json`);

interface Recommendation {
  quote: string;
  author: string;
  title: string;
  date: string;
  avatar?: string;
}
---

<section id="recommendations" aria-label="Recommendations" class="section">
  <h2 class="section-label">{t('recommendations.title')}</h2>

  <div class="recommendations-list">
    {data.featured.map((rec: Recommendation) => (
      <RecommendationCard
        quote={rec.quote}
        author={rec.author}
        title={rec.title}
        date={rec.date}
        avatar={rec.avatar}
      />
    ))}
  </div>
</section>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin: 0 0 48px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-accent), transparent);
    opacity: 0.35;
  }

  @media (max-width: 1023px) {
    .section-label {
      position: sticky;
      top: 0;
      z-index: 5;
      padding: 16px 0;
      background-color: color-mix(in srgb, var(--color-bg) 80%, transparent);
      backdrop-filter: blur(8px);
      margin: 0 0 24px;
    }
  }

  .recommendations-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
</style>
