---
import RecommendationCard from '../ui/RecommendationCard.astro';
import SectionLabel from '../ui/SectionLabel.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const data = await import(`../../data/${lang}/recommendations.json`);

interface Recommendation {
  quote: string;
  author: string;
  title: string;
  date: string;
  avatar?: string;
}
---

<section id="recommendations" aria-label="Recommendations" class="section" data-reveal>
  <SectionLabel>{t('recommendations.title')}</SectionLabel>

  <div class="recommendations-list">
    {data.featured.map((rec: Recommendation) => (
      <RecommendationCard
        quote={rec.quote}
        author={rec.author}
        title={rec.title}
        date={rec.date}
        avatar={rec.avatar}
      />
    ))}
  </div>
</section>

<style>
  .recommendations-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
</style>
