---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  class="theme-toggle"
  data-theme-toggle
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: 4px;
    transition: color 0.2s ease-in-out;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
  }

  /* Dark mode (default): show sun, hide moon */
  .icon-moon { display: none; }
  .icon-sun { display: block; }

  /* Light mode: show moon, hide sun */
  :global(.light) .icon-sun { display: none; }
  :global(.light) .icon-moon { display: block; }
</style>

<script>
  let themeController: AbortController | null = null;

  function initThemeToggle() {
    // Abort any previous listener before re-registering
    themeController?.abort();
    themeController = new AbortController();

    const btns = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');
    if (!btns.length) return;

    function updateLabels() {
      const isLight = document.documentElement.classList.contains('light');
      btns.forEach(btn =>
        btn.setAttribute('aria-label', isLight ? 'Switch to dark mode' : 'Switch to light mode')
      );
    }

    updateLabels();

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        updateLabels();
      }, { signal: themeController!.signal });
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
